# Postgres (consumido por docker-compose, api y etl)
POSTGRES_USER=tuki
POSTGRES_PASSWORD=tuki_dev
POSTGRES_DB=tuki_expertia
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API
API_PORT=3000
API_CORS_ORIGIN=http://localhost:8081,http://localhost:4200

# Auth — JWT secret (cambiar en producción)
JWT_SECRET=cambiame-en-produccion-este-secreto-debe-ser-largo-y-aleatorio-64-chars-min
JWT_EXPIRES_IN=12h
COOKIE_SECURE=false        # true en producción con HTTPS
COOKIE_SAMESITE=lax        # lax en dev (mismo origen via nginx); none + secure en prod cross-domain

# Usuarios autorizados (se seedean al arranque del API si no existen)
TUKI_USERNAME=tuki
TUKI_PASSWORD=Tuki-2026-Awesome!
TUKI_DISPLAY_NAME=TukiTuki
TUKI_ORG=tukituki

EXPERTIA_USERNAME=expertia
EXPERTIA_PASSWORD=Expertia-2026-Prospect!
